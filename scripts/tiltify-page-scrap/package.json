{
  "name": "tiltify-page-scrap",
  "version": "1.0.0",
  "description": "Scrapes the Live Donation table from a Tiltify campaign page",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "ts-node src/index.ts",
