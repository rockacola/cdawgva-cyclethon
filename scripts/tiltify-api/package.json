{
  "name": "tiltify-api",
  "version": "1.0.0",
  "description": "Scripts for querying the Tiltify API",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "get-user-by-slug": "ts-node src/get-user-by-slug.ts",
    "get-user-campaigns": "ts-node src/get-user-campaigns.ts",
    "generate:types": "openapi-typescript https://v5api.tiltify.com/api/public/openapi -o src/types/api.ts",
    "lint": "eslint .",
    "format": "prettier --write .",
    "format:check": "prettier --check ."
  },
  "dependencies": {
    "dotenv": "^16.0.0",
    "openapi-fetch": "^0.17.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@types/node": "^20.0.0",
    "eslint": "^9.39.4",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-import": "^2.32.0",
    "globals": "^17.4.0",
    "openapi-typescript": "^7.13.0",
    "prettier": "^3.8.1",
    "ts-node": "^10.9.0",
    "typescript": "^5.0.0",
    "typescript-eslint": "^8.57.0"
  }
}
