# Tiltify API credentials
# Create an application at: tiltify.com → account settings → Applications
TILTIFY_CLIENT_ID=
TILTIFY_CLIENT_SECRET=

# Cloudflare R2
# Account ID: Cloudflare dashboard → right sidebar
# Access key: R2 → Manage R2 API Tokens → Create API Token (Object Read & Write)
# Bucket name: the R2 bucket you created
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=
